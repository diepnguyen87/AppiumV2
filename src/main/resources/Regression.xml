<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="Regression" parallel="tests" thread-count="2">
    <!--   <listeners>
           <listener class-name="retry.RetryListener"/>
       </listeners>
   -->
    <test name="Authentication">
        <parameter name="platformName" value="android"/>
        <parameter name="udid" value="${udid}"/>
        <parameter name="systemPort" value="7001"/>
        <classes>
            <class name="tests.authentication.TestLogin"/>
            <class name="tests.authentication.TestLoginWithBaseTest"/>
        </classes>
    </test>

    <test name="Webview" >
        <parameter name="platformName" value="ios" />
        <parameter name="platformVersion" value="16.4" />
        <parameter name="udid" value="${udid}" />
        <parameter name="systemPort" value="8100" />
        <classes>
            <class name="tests.webview.HydridContext"/>
            <class name="tests.swipe.SwipeHorizontal"/>
        </classes>
    </test>
</suite>