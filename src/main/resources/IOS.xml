<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="IOS Regression">
    <test name="Webview" >
        <parameter name="platformName" value="ios" />
        <parameter name="platformVersion" value="16.4" />
        <parameter name="udid" value="${udid}" />
